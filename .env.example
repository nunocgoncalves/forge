# Copy to .env and fill in. .env is gitignored; never commit secrets.
# The Makefile loads .env automatically (`-include .env` + `export`).

# DigitalOcean API token (read/write) — required for `make test-e2e` and the
# e2e/reaper GitHub workflows.
# Create at: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=

# Set to 1 to keep the e2e droplet after the run (for debugging).
FORGE_E2E_KEEP=
